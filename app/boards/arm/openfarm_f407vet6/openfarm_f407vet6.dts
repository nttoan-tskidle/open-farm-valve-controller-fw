/dts-v1/;
#include <st/f4/stm32f407Xe.dtsi>
#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
	model = "OpenFarm STM32F407VET6";
	compatible = "openfarm,stm32f407vet6";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
	};

	aliases {
		led-heartbeat = &led_heartbeat;
		led-uart = &led_uart;
		led-wifi = &led_wifi;
		led-sim = &led_sim;
		led-mqtt = &led_mqtt;
		led-flash = &led_flash;
		led-valve = &led_valve;
	};

		leds {
		compatible = "gpio-leds";

		led_heartbeat: led_heartbeat {
			gpios = <&gpioa 0 GPIO_ACTIVE_HIGH>;
			label = "Heartbeat LED";
		};

		led_uart: led_uart {
			gpios = <&gpioa 1 GPIO_ACTIVE_HIGH>;
			label = "UART LED";
		};

		led_wifi: led_wifi {
			gpios = <&gpioa 2 GPIO_ACTIVE_HIGH>;
			label = "WiFi LED";
		};

		led_sim: led_sim {
			gpios = <&gpioa 3 GPIO_ACTIVE_HIGH>;
			label = "SIMCOM LED";
		};

		led_mqtt: led_mqtt {
			gpios = <&gpioa 4 GPIO_ACTIVE_HIGH>;
			label = "MQTT LED";
		};

		led_flash: led_flash {
			gpios = <&gpioa 5 GPIO_ACTIVE_HIGH>;
			label = "External Flash LED";
		};

		led_valve: led_valve {
			gpios = <&gpioa 6 GPIO_ACTIVE_HIGH>;
			label = "Valve LED";
		};
	};
};

&clk_hse {
	clock-frequency = <8000000>;
	status = "okay";
};

&pll {
	clocks = <&clk_hse>;
	div-m = <8>;
	mul-n = <336>;
	div-p = <2>;
	div-q = <7>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <168000000>;
	ahb-prescaler = <1>;
	apb1-prescaler = <4>;
	apb2-prescaler = <2>;
};